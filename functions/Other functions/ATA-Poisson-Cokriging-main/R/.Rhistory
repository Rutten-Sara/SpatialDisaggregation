set.seed(1)
pesticide_A <- data.frame(Eiermassa=2+2*rchisq(18,1.9),
Uitkomstpercentage=sample(40:70, 18, replace=T),Pesticide = "A")
set.seed(6)
pesticide_C <- data.frame(Eiermassa=rnorm(17,5.4,1),
Uitkomstpercentage=sample(50:90, 17, replace=T),Pesticide = "C")
pesticide_data <- rbind(pesticide_A,pesticide_C)
pesticide_data$Broedtijd = rnorm(35,8.5,1.2)
# Vraag a)
library(nortest)
shapiro.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="A"])
lillie.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="A"])
cvm.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="A"])
ad.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="A"])
shapiro.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="C"])
lillie.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="C"])
cvm.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="C"])
ad.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="C"])
table(pesticide_data$Pesticide)
summary(pesticide_data$Eiermassa[pesticide_data$Pesticide=="A"])
summary(pesticide_data$Eiermassa[pesticide_data$Pesticide=="C"])
var(pesticide_data$Eiermassa[pesticide_data$Pesticide=="A"])
var(pesticide_data$Eiermassa[pesticide_data$Pesticide=="C"])
t.test(pesticide_data$Eiermassa[pesticide$Pesticide=="A"],mu=6,conf.level=0.99,alternative="less")
t.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="A"],mu=6,conf.level=0.99,alternative="less")
t.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="A"],mu=6,conf.level=0.99,alternative="greater")
t.test(pesticide_data$Eiermassa[pesticide_data$Pesticide=="A"],mu=6,conf.level=0.99,alternative="two.sided")
#################### Vraag hypothesetesten 2 groepen ###########################
set.seed(1)
n <- 150 # Aantal waarnemingen
Habitat <- c(rep(1,15*n/30), rep(2,9*n/30), rep(3,6*n/30))
Geslacht <- rep(0,n)
Geslacht[Habitat==1] <- sample(c(1, 2), sum(Habitat==1), replace = TRUE)
Geslacht[Habitat==2] <- sample(c(1,1, 2), sum(Habitat==2), replace = TRUE)
Geslacht[Habitat==3] <- sample(c(1, 2), sum(Habitat==3), replace = TRUE)
Voedingsstatus_voor = rep(0,n)
Voedingsstatus_voor[Habitat==1] = rnorm(15*n/30,30,5)
Voedingsstatus_voor[Habitat==2] = rnorm(9*n/30,25,4)
Voedingsstatus_voor[Habitat==3] = rnorm(6*n/30,35,6)
Voedingsstatus_na = Voedingsstatus_voor - rnorm(n,0,1)
Zeehond <- data.frame(Habitat = Habitat, Geslacht = Geslacht, Voedingsstatus_voor = Voedingsstatus_voor,
Voedingsstatus_na = Voedingsstatus_na)
# Vraag a)
Zeehond_kust <- Zeehond[Zeehond$Habitat==1,]
dim(Zeehond_kust)
var.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="two.sided")
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="two.sided", paired=T)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="two.sided", var.equal=T)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="two.sided", var.equal=F)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="greater", paired=T)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="greater", var.equal=T)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="greater", var.equal=F)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="less", paired=T)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="less", var.equal=T)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="less", var.equal=F)
# Vraag b)
table(Zeehond$Habitat)
sum(Zeehond$Voedingsstatus_voor[Zeehond$Habitat==2]>=22 & Zeehond$Voedingsstatus_voor[Zeehond$Habitat==2]<= 37)
sum(Zeehond$Voedingsstatus_voor[Zeehond$Habitat==3]>=22 & Zeehond$Voedingsstatus_voor[Zeehond$Habitat==3]<= 37)
sum(Zeehond$Voedingsstatus_na[Zeehond$Habitat==2]>=22 & Zeehond$Voedingsstatus_na[Zeehond$Habitat==2]<= 37)
sum(Zeehond$Voedingsstatus_na[Zeehond$Habitat==3]>=22 & Zeehond$Voedingsstatus_na[Zeehond$Habitat==3]<= 37)
prop.test(x=c(37,16), n=c(45,30))
prop.test(x=c(37,16), n=c(45,30), correct=F)
table(Zeehond$Habitat, Zeehond$Geslacht)
chisq.test(table(Zeehond$Habitat, Zeehond$Geslacht))$expected
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="less", paired=T)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="less", var.equal=T)
t.test(Zeehond_kust$Voedingsstatus_voor, Zeehond_kust$Voedingsstatus_na,alternative="less", var.equal=F)
